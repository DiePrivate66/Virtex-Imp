# Bosco production environment template.
# Copy values into Railway/hosting variables. Do not commit real secrets.

# Core Django / deployment
DEBUG=False
SECRET_KEY=change-me
DATABASE_URL=
ALLOWED_HOSTS=your-backend.railway.app,.railway.app
CSRF_TRUSTED_ORIGINS=https://your-backend.railway.app,https://*.railway.app
CORS_ALLOWED_ORIGINS=https://your-frontend.app
CORS_ALLOW_ALL_ORIGINS=False
PUBLIC_PWA_URL=https://your-frontend.app
PUBLIC_BACKEND_URL=https://your-backend.railway.app

# Email / receipts
EMAIL_BACKEND=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=RAMON by Bosco <no-reply@example.com>
RESEND_API_KEY=
RESEND_API_BASE=https://api.resend.com
RESEND_API_TIMEOUT_SECONDS=15

# PayPhone web checkout
PAYPHONE_ENABLED=False
PAYPHONE_API_BASE=https://pay.payphonetodoesposible.com
PAYPHONE_TOKEN=
PAYPHONE_STORE_ID=
PAYPHONE_TIMEOUT_SECONDS=15

# Meta WhatsApp
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_API_VERSION=v22.0
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_APP_SECRET=
META_SIGNATURE_VALIDATION=True
WHATSAPP_WEBHOOK_VERIFY=
WHATSAPP_INBOUND_RATE_LIMIT_WINDOW_SECONDS=60
WHATSAPP_INBOUND_RATE_LIMIT_MAX=20

# Telegram alerts / delivery group
TELEGRAM_BOT_TOKEN=
TELEGRAM_DELIVERY_GROUP_ID=
TELEGRAM_ADMIN_ALERT_CHAT_ID=
TELEGRAM_API_TIMEOUT_SECONDS=10
TELEGRAM_CIRCUIT_FAILURE_THRESHOLD=3
TELEGRAM_CIRCUIT_OPEN_SECONDS=180
TELEGRAM_CIRCUIT_REDIS_TIMEOUT_SECONDS=0.2

# Async runtime
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# Operational timeouts / cleanup
DELIVERY_QUOTE_TIMEOUT_SECONDS=180
DELIVERY_QUOTE_TOKEN_MAX_AGE_SECONDS=900
PRINT_JOB_STUCK_SECONDS=120
OUTBOX_STALE_SECONDS=300
OUTBOX_PRIORITY_AGING_STEP_SECONDS=300
OUTBOX_PRIORITY_AGING_FACTOR=5
OUTBOX_SWEEP_FETCH_LIMIT=1000
OUTBOX_SWEEP_BATCH_SIZE=200
IDEMPOTENCY_TTL_HOURS=24
PENDING_PAYMENT_TIMEOUT_SECONDS=600
PENDING_PAYMENT_REAPER_BATCH_SIZE=50
MAX_OPEN_CASH_TURN_HOURS=20
IDEMPOTENCY_PURGE_AFTER_HOURS=168
IDEMPOTENCY_PURGE_BATCH_SIZE=1000

# Ledger registry / replay admission
LEDGER_VERSION_FENCING_ENABLED=True
LEDGER_ACTIVATION_CACHE_TTL_SECONDS=5
LEDGER_WEB_CLIENT_APP_VERSION=pos-web
POS_REPLAY_ADMISSION_ENABLED=True
POS_REPLAY_GLOBAL_SLOTS=8
POS_REPLAY_ORGANIZATION_SLOTS=1
POS_REPLAY_COLD_LANE_SLOTS=2
POS_REPLAY_COLD_LANE_HOURS=48
POS_REPLAY_SLOT_TTL_SECONDS=15
POS_REPLAY_RETRY_AFTER_SECONDS=5

# Dedicated replay gateway wrapper
REPLAY_GATEWAY_ENABLED=False
REPLAY_GATEWAY_UPSTREAM_HOST=127.0.0.1
REPLAY_GATEWAY_UPSTREAM_PORT=18000
REPLAY_GATEWAY_TOTAL_TIMEOUT_SECONDS=10
REPLAY_GATEWAY_IDLE_TIMEOUT_SECONDS=5
REPLAY_GATEWAY_UPSTREAM_TIMEOUT_SECONDS=120
REPLAY_GATEWAY_COLD_LANE_HOURS=48
REPLAY_GATEWAY_COLD_LANE_SLOTS=2
REPLAY_GATEWAY_COLD_SLICE_SECONDS=120
REPLAY_GATEWAY_WAITER_TTL_SECONDS=30
REPLAY_GATEWAY_BUCKET_COUNT=8
REPLAY_COORDINATOR_BACKEND=redis
REPLAY_COORDINATOR_REDIS_URL=
REPLAY_TICKET_TTL_SECONDS=30
REPLAY_HEARTBEAT_INTERVAL_SECONDS=10
REPLAY_MAX_WAITERS_PER_BUCKET=100

# Offline journal / limbo / retention
OFFLINE_JOURNAL_ENABLED=False
OFFLINE_JOURNAL_ROOT=
OFFLINE_JOURNAL_STREAM_NAME=sales
OFFLINE_JOURNAL_SEGMENT_MAX_BYTES=104857600
OFFLINE_JOURNAL_LIMBO_RECENT_LIMIT=50
OFFLINE_JOURNAL_HISTORY_LIMIT=5
OFFLINE_JOURNAL_SIDECAR_MAX_BYTES=65536
OFFLINE_JOURNAL_PROJECTION_WINDOW_HOURS=24
OFFLINE_JOURNAL_RECEIPT_SECRET=
OFFLINE_JOURNAL_CAPTURE_SERVER_EVENTS=False
OPS_PREFLIGHT_OFFLINE_CAPTURE_LOOKBACK_HOURS=24
OPS_PREFLIGHT_OPERATIONAL_DRIFT_LOOKBACK_HOURS=72
OPS_PREFLIGHT_REPLAY_ALERT_STALE_HOURS=24

# Business rules
ENABLE_BUSINESS_HOURS=True
